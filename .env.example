TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=
PORT=3000
APP_BASE_URL=https://your-public-domain.example.com

DB_USER=postgres
DB_HOST=localhost
DB_PASSWORD=
DB_NAME=progressbar_tn
DB_PORT=5432
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=5000
